getOption("aquaman.data_dir", default = rappdirs::user_data_dir("aquaman"))
data_dir <- function() {
getOption("aquaman.data_dir", default = rappdirs::user_data_dir("aquaman"))
}
check_write_to_data_dir <- function(dir, ask) {
if (ask) {
ans <- ask(paste("scotmaps would like to store this layer in the directory:",
dir, "Is that okay?", sep = "\n"))
if (!ans) stop("Exiting...", call. = FALSE)
}
}
check_write_to_data_dir(data_dir(), ask = TRUE)
check_write_to_data_dir(data_dir(), TRUE)
check_write_to_data_dir <- function(dir, ask) {
if (ask) {
ans <- ask(paste("scotmaps would like to store this layer in the directory:",
dir, "Is that okay?", sep = "\n"))
if (!ans) stop("Exiting...", call. = FALSE)
}
}
check_write_to_data_dir(data_dir(), ask= TRUE)
ask <- function(...) {
choices <- c("Yes", "No")
cat(paste0(..., collapse = ""))
utils::menu(choices) == which(choices == "Yes")
}
