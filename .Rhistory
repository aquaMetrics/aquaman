file_download <- function() {
browser()
data_dir <- function() {
getOption("aquaman.data_dir", default = rappdirs::user_data_dir("aquaman"))
}
fpath <- paste0(data_dir(), "/silva_nr99_v138.1_train_set.fa.gz")
